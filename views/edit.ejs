<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Website Description : to be added later"
    />
    <title>Notes App</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link rel="stylesheet" href="/styles/edit_style.css" />
    <link rel="icon" href="favicon.ico" />
  </head>
  <body>
    <header>
      <div class="brand">Notes</div>
      <li><a href="/">Home</a></li>
      <li><a href="/">Support</a></li>
      <button class="mode"></button>
      <!-- <div class="account">
        <li class="login">Login</li>
        <li class="sign_up">Sign up</li>
      </div> -->
    </header>
    <div class="form">
      <form action="/edit/<%= filename %>" method="POST">
        <input
          type="hidden"
          name="previous_file_name"
          value="<%= filename %>"
        />

        <div class="edit-container">
          <div class="old-note">
            <h3>Previous Note</h3>

            <div class="note_heading_prev"><%= displayname %></div>

            <textarea class="note_content" readonly><%= content %></textarea>
          </div>

          <div class="new-note">
            <h3>Edit Note</h3>

            <input
              type="text"
              name="new_file_name"
              value="<%= displayname %>"
            />

            <textarea name="new_body"><%= content %></textarea>

            <input type="submit" value="Update Note" />
          </div>
        </div>
      </form>
    </div>
    <script src="/javascripts/edit_script.js"></script>
    <script src="/javascripts/script.js"></script>
  </body>
</html>

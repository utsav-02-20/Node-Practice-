<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Website Description : to be added later"
    />
    <title>Notes App</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link rel="stylesheet" href="/styles/style.css">
    <link rel="icon" href="favicon.ico" />
  </head>
  <body>
    <header>
      <div class="brand">Notes</div>
      <a href="/">Home</a>
      <li>Support</li>
      <button class="mode"></button>
      <!-- <div class="account">
        <li class="login">Login</li>
        <li class="sign_up">Sign up</li>
      </div> -->
    </header>


    <div class="saved_notes">
        <div class="notes">
            <a class="note_heading"><%= displayname %></a>
            <textarea class="note_content" readonly><%= content %></textarea>
        </div>
    </div>

    <script src="/javascripts/script.js"></script>
  </body>
</html>
